{
  "name": "krown-level-enterprises",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Krown Level Enterprises — Community sustainability through agriculture education, wellness education, financial literacy, and self-defense.",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node server/dist/server/src/index.js",
    "preview": "vite preview",
    "seed:production": "tsx server/src/scripts/seedProduction.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.server.json --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "argon2": "^0.44.0",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "framer-motion": "^11.0.0",
    "helmet": "^8.2.0",
    "lucide-react": "^0.344.0",
    "mongoose": "^8.24.0",
    "multer": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-intersection-observer": "^9.8.0",
    "resend": "^4.8.0",
    "sharp": "^0.33.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.0",
    "@types/supertest": "^7.2.0",
    "@vercel/node": "^5.5.16",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.1.0",
    "vitest": "^1.6.0"
  }
}
