PORT=3000
NODE_ENV=development
APP_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/krownlevelent
SESSION_SECRET=replace-with-a-long-random-secret
